# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — https://supabase.com/dashboard → your project
# Settings → API: Project URL, Publishable (browser), Secret (server, bypasses RLS).
# Settings → API → JWT Settings: JWT Secret → SUPABASE_JWT_KEY (signing; not the Secret API key).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_KEY=

# Naver Map
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=
NEXT_PUBLIC_NAVER_MAP_API_URL=https://openapi.map.naver.com/openapi/v3/maps.js

# Gemini
GEMINI_API_KEY=